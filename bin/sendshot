#!/usr/bin/env bash
set -Eeuo pipefail

VERSION="0.2.3"

CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/sendshot"
CONFIG_FILE="$CONFIG_DIR/config"

UPDATE_REPOSITORY="${SENDSHOT_UPDATE_REPOSITORY:-hinson0/sendshot}"
UPDATE_BRANCH="${SENDSHOT_UPDATE_BRANCH:-main}"
UPDATE_RAW_BASE="${SENDSHOT_UPDATE_RAW_BASE:-https://raw.githubusercontent.com/$UPDATE_REPOSITORY/$UPDATE_BRANCH}"
UPDATE_CACHE_DIR="${XDG_CACHE_HOME:-$HOME/.cache}/sendshot"
UPDATE_CHECK_FILE="$UPDATE_CACHE_DIR/last-update-check"
UPDATE_INTERVAL_SECONDS="${SENDSHOT_UPDATE_INTERVAL_SECONDS:-86400}"

log() {
  printf 'sendshot: %s\n' "$*" >&2
}

die() {
  log "$*"
  exit 1
}

command_exists() {
  command -v "$1" >/dev/null 2>&1
}

expand_home() {
  local value="$1"

  case "$value" in
    "~")
      printf '%s\n' "$HOME"
      ;;
    "~/"*)
      printf '%s/%s\n' "$HOME" "${value:2}"
      ;;
    *)
      printf '%s\n' "$value"
      ;;
  esac
}

prompt_value() {
  local variable_name="$1"
  local label="$2"
  local default_value="${3:-}"
  local required="${4:-0}"
  local value=""

  if [[ "${SENDSHOT_NON_INTERACTIVE:-0}" == "1" ]]; then
    value="$default_value"
  elif [[ -r /dev/tty ]]; then
    if [[ -n "$default_value" ]]; then
      read -r -p "$label [$default_value]: " value </dev/tty || true
    else
      read -r -p "$label: " value </dev/tty || true
    fi
    value="${value:-$default_value}"
  else
    value="$default_value"
  fi

  if [[ "$required" == "1" && -z "$value" ]]; then
    die "$label is required"
  fi

  printf -v "$variable_name" '%s' "$value"
}

ask_yes_no() {
  local prompt="$1"
  local default="${2:-yes}"
  local answer=""

  if [[ "${SENDSHOT_NON_INTERACTIVE:-0}" == "1" || ! -r /dev/tty ]]; then
    [[ "$default" == "yes" ]]
    return
  fi

  if [[ "$default" == "yes" ]]; then
    read -r -p "$prompt [Y/n]: " answer </dev/tty || true
    answer="${answer:-y}"
  else
    read -r -p "$prompt [y/N]: " answer </dev/tty || true
    answer="${answer:-n}"
  fi

  [[ "$answer" =~ ^[Yy]([Ee][Ss])?$ ]]
}

fetch_url() {
  local url="$1"
  local destination="${2:-}"

  if command_exists curl; then
    if [[ -n "$destination" ]]; then
      curl -fsSL \
        --connect-timeout 5 \
        --max-time 30 \
        "$url" \
        -o "$destination"
    else
      curl -fsSL \
        --connect-timeout 5 \
        --max-time 30 \
        "$url"
    fi
  elif command_exists wget; then
    if [[ -n "$destination" ]]; then
      wget -q --timeout=30 -O "$destination" "$url"
    else
      wget -q --timeout=30 -O- "$url"
    fi
  else
    die "curl or wget is required for updates"
  fi
}

extract_version_from_file() {
  local file="$1"
  sed -nE 's/^VERSION="([^"]+)".*/\1/p' "$file" | head -n 1
}

version_is_newer() {
  local latest="${1%%[-+]*}"
  local current="${2%%[-+]*}"
  local latest_major latest_minor latest_patch
  local current_major current_minor current_patch

  IFS=. read -r latest_major latest_minor latest_patch <<<"$latest"
  IFS=. read -r current_major current_minor current_patch <<<"$current"

  latest_major="${latest_major:-0}"
  latest_minor="${latest_minor:-0}"
  latest_patch="${latest_patch:-0}"
  current_major="${current_major:-0}"
  current_minor="${current_minor:-0}"
  current_patch="${current_patch:-0}"

  [[ "$latest_major" =~ ^[0-9]+$ ]] || return 1
  [[ "$latest_minor" =~ ^[0-9]+$ ]] || return 1
  [[ "$latest_patch" =~ ^[0-9]+$ ]] || return 1
  [[ "$current_major" =~ ^[0-9]+$ ]] || return 1
  [[ "$current_minor" =~ ^[0-9]+$ ]] || return 1
  [[ "$current_patch" =~ ^[0-9]+$ ]] || return 1

  ((latest_major > current_major)) && return 0
  ((latest_major < current_major)) && return 1

  ((latest_minor > current_minor)) && return 0
  ((latest_minor < current_minor)) && return 1

  ((latest_patch > current_patch))
}

resolve_self_path() {
  local path="${BASH_SOURCE[0]}"

  if [[ "$path" != /* ]]; then
    path="$(command -v "$path" 2>/dev/null || printf '%s' "$path")"
  fi

  local directory
  directory="$(cd -P "$(dirname "$path")" && pwd)"

  printf '%s/%s\n' "$directory" "$(basename "$path")"
}

record_update_check() {
  mkdir -p "$UPDATE_CACHE_DIR"
  date +%s >"$UPDATE_CHECK_FILE"
}

should_check_for_update() {
  [[ "${SENDSHOT_NO_UPDATE_CHECK:-0}" != "1" ]] || return 1
  [[ "$UPDATE_INTERVAL_SECONDS" =~ ^[0-9]+$ ]] || return 1

  local now last_check=0
  now="$(date +%s)"

  if [[ -f "$UPDATE_CHECK_FILE" ]]; then
    read -r last_check <"$UPDATE_CHECK_FILE" || last_check=0
  fi

  [[ "$last_check" =~ ^[0-9]+$ ]] || last_check=0

  ((now - last_check >= UPDATE_INTERVAL_SECONDS))
}

download_latest_source() {
  local destination="$1"

  fetch_url "$UPDATE_RAW_BASE/bin/sendshot" "$destination" ||
    return 1

  [[ -s "$destination" ]] || return 1
  bash -n "$destination" || return 1
}

install_update_file() {
  local source_file="$1"
  local target_file="$2"

  [[ -w "$target_file" ]] ||
    die "cannot update $target_file; check its ownership and permissions"

  install -m 0755 "$source_file" "$target_file"
}

download_shell_integration() {
  local shell_name="$1"
  local destination="$2"

  fetch_url "$UPDATE_RAW_BASE/shell/sendshot.$shell_name" "$destination" ||
    return 1

  [[ -s "$destination" ]] || return 1

  case "$shell_name" in
    zsh)
      if command_exists zsh; then
        zsh -n "$destination" || return 1
      fi
      ;;
    bash)
      bash -n "$destination" || return 1
      ;;
    *)
      return 1
      ;;
  esac
}

refresh_shell_integrations() {
  local shell_name target temporary_file
  local refreshed=0

  mkdir -p "$CONFIG_DIR"

  for shell_name in zsh bash; do
    target="$CONFIG_DIR/sendshot.$shell_name"

    # Refresh integrations that are already installed.
    [[ -f "$target" ]] || continue

    temporary_file="$(mktemp "${TMPDIR:-/tmp}/sendshot-shell.XXXXXX")"

    if download_shell_integration "$shell_name" "$temporary_file"; then
      install -m 0644 "$temporary_file" "$target"
      log "updated shell integration: $target"
      refreshed=1
    else
      log "warning: failed to update shell integration: $shell_name"
    fi

    rm -f "$temporary_file"
  done

  # When called explicitly and no integration exists yet, install one for the
  # user's current shell. The rc source block is normally created by install.sh.
  if ((refreshed == 0)); then
    case "${SHELL:-}" in
      */zsh) shell_name="zsh" ;;
      */bash) shell_name="bash" ;;
      *)
        log "warning: only bash and zsh hotkeys are supported"
        return 1
        ;;
    esac

    target="$CONFIG_DIR/sendshot.$shell_name"
    temporary_file="$(mktemp "${TMPDIR:-/tmp}/sendshot-shell.XXXXXX")"

    if ! download_shell_integration "$shell_name" "$temporary_file"; then
      rm -f "$temporary_file"
      die "failed to download the $shell_name integration"
    fi

    install -m 0644 "$temporary_file" "$target"
    rm -f "$temporary_file"
    log "installed shell integration: $target"
  fi
}

perform_update() {
  local force="${1:-0}"
  local temporary_file latest_version self_path

  temporary_file="$(mktemp "${TMPDIR:-/tmp}/sendshot-update.XXXXXX")"

  if ! download_latest_source "$temporary_file"; then
    rm -f "$temporary_file"
    die "failed to download or validate the latest version"
  fi

  latest_version="$(extract_version_from_file "$temporary_file")"

  if [[ -z "$latest_version" ]]; then
    rm -f "$temporary_file"
    die "latest source does not contain a VERSION"
  fi

  if [[ "$force" != "1" ]] && ! version_is_newer "$latest_version" "$VERSION"; then
    rm -f "$temporary_file"
    record_update_check
    log "already up to date: $VERSION"
    return 0
  fi

  self_path="$(resolve_self_path)"
  install_update_file "$temporary_file" "$self_path"
  rm -f "$temporary_file"
  refresh_shell_integrations || true
  record_update_check

  log "updated: $VERSION -> $latest_version"
}

check_update_interactive() {
  local mode="${1:-automatic}"
  shift || true

  local temporary_file latest_version self_path

  temporary_file="$(mktemp "${TMPDIR:-/tmp}/sendshot-check.XXXXXX")"

  # 无网络时不影响 sendshot 的正常上传。
  if ! download_latest_source "$temporary_file"; then
    rm -f "$temporary_file"

    if [[ "$mode" == "manual" ]]; then
      log "unable to check for updates"
      return 1
    fi

    return 0
  fi

  latest_version="$(extract_version_from_file "$temporary_file")"
  record_update_check

  if [[ -z "$latest_version" ]]; then
    rm -f "$temporary_file"

    if [[ "$mode" == "manual" ]]; then
      log "latest source does not contain a VERSION"
      return 1
    fi

    return 0
  fi

  if ! version_is_newer "$latest_version" "$VERSION"; then
    rm -f "$temporary_file"

    if [[ "$mode" == "manual" ]]; then
      log "already up to date: $VERSION"
    fi

    return 0
  fi

  log "update available: $VERSION -> $latest_version"

  # 非交互环境只提示，不阻塞，也不自动覆盖。
  if [[ ! -r /dev/tty || "${SENDSHOT_NON_INTERACTIVE:-0}" == "1" ]]; then
    rm -f "$temporary_file"
    log "run: sendshot update"
    return 0
  fi

  if ! ask_yes_no "Update now?" yes; then
    rm -f "$temporary_file"
    log "update skipped"
    return 0
  fi

  self_path="$(resolve_self_path)"
  install_update_file "$temporary_file" "$self_path"
  rm -f "$temporary_file"
  refresh_shell_integrations || true

  log "updated: $VERSION -> $latest_version"

  # 立即使用新版本继续执行用户原本输入的命令。
  if (($# > 0)); then
    SENDSHOT_NO_UPDATE_CHECK=1 exec "$self_path" "$@"
  fi
}

maybe_check_for_update() {
  should_check_for_update || return 0
  check_update_interactive automatic "$@"
}

load_config() {
  REMOTE_USER=""
  REMOTE_HOST=""
  SSH_KEY=""
  SSH_PORT="22"
  REMOTE_DIR="~/tmp_images"

  if [[ -f "$CONFIG_FILE" ]]; then
    # This file is generated by sendshot, owned by the current user and chmod 600.
    # shellcheck source=/dev/null
    source "$CONFIG_FILE"
  fi
}

write_config() {
  local remote_user="$1"
  local remote_host="$2"
  local ssh_key="$3"
  local ssh_port="$4"
  local remote_dir="$5"
  local tmp

  mkdir -p "$CONFIG_DIR"
  chmod 700 "$CONFIG_DIR"

  tmp="$(mktemp "$CONFIG_DIR/config.XXXXXX")"
  chmod 600 "$tmp"

  {
    printf '# Generated by sendshot. Re-run `sendshot config` to update.\n'
    printf 'REMOTE_USER=%q\n' "$remote_user"
    printf 'REMOTE_HOST=%q\n' "$remote_host"
    printf 'SSH_KEY=%q\n' "$ssh_key"
    printf 'SSH_PORT=%q\n' "$ssh_port"
    printf 'REMOTE_DIR=%q\n' "$remote_dir"
  } >"$tmp"

  mv "$tmp" "$CONFIG_FILE"
  chmod 600 "$CONFIG_FILE"

  log "configuration saved to $CONFIG_FILE"
}

build_ssh_args() {
  SSH_ARGS=(
    -p "$SSH_PORT"
    -o ConnectTimeout=10
    -o StrictHostKeyChecking=accept-new
  )

  SCP_ARGS=(
    -P "$SSH_PORT"
    -o ConnectTimeout=10
    -o StrictHostKeyChecking=accept-new
  )

  if [[ -n "$SSH_KEY" ]]; then
    local expanded_key
    expanded_key="$(expand_home "$SSH_KEY")"
    [[ -f "$expanded_key" ]] || die "SSH key not found: $expanded_key"
    SSH_ARGS+=(-i "$expanded_key")
    SCP_ARGS+=(-i "$expanded_key")
  fi
}

test_connection() {
  load_config
  [[ -n "$REMOTE_HOST" ]] || die "not configured; run: sendshot config"
  [[ -n "$REMOTE_USER" ]] || die "REMOTE_USER is missing"

  build_ssh_args

  local target="${REMOTE_USER}@${REMOTE_HOST}"
  log "testing SSH connection to $target:$SSH_PORT"

  ssh "${SSH_ARGS[@]}" -o BatchMode=yes "$target" 'printf ok' |
    grep -qx 'ok' ||
    die "SSH connection test failed"

  log "SSH connection successful"
}

configure() {
  load_config

  local remote_user remote_host ssh_key ssh_port remote_dir

  prompt_value \
    remote_user \
    "Remote SSH user" \
    "${SENDSHOT_REMOTE_USER:-${REMOTE_USER:-ubuntu}}"

  prompt_value \
    remote_host \
    "Remote host/IP or SSH alias" \
    "${SENDSHOT_REMOTE_HOST:-$REMOTE_HOST}" \
    1

  prompt_value \
    ssh_key \
    "SSH private key path (empty = SSH config/agent)" \
    "${SENDSHOT_SSH_KEY:-$SSH_KEY}"

  prompt_value \
    ssh_port \
    "SSH port" \
    "${SENDSHOT_SSH_PORT:-${SSH_PORT:-22}}" \
    1

  prompt_value \
    remote_dir \
    "EC2 remote image directory" \
    "${SENDSHOT_REMOTE_DIR:-${REMOTE_DIR:-~/tmp_images}}" \
    1

  [[ "$ssh_port" =~ ^[0-9]+$ ]] || die "SSH port must be a number"
  [[ "$remote_dir" != *$'\n'* ]] || die "remote directory cannot contain a newline"

  if [[ -n "$ssh_key" ]]; then
    local expanded_key
    expanded_key="$(expand_home "$ssh_key")"
    [[ -f "$expanded_key" ]] ||
      log "warning: SSH key does not currently exist: $expanded_key"
  fi

  write_config "$remote_user" "$remote_host" "$ssh_key" "$ssh_port" "$remote_dir"

  if ask_yes_no "Test SSH connection now?" yes; then
    test_connection
  fi
}

choose_wayland_mime() {
  local types="$1"
  local mime

  for mime in image/png image/jpeg image/webp image/bmp image/tiff; do
    if grep -Fxq "$mime" <<<"$types"; then
      printf '%s\n' "$mime"
      return 0
    fi
  done

  return 1
}

extension_for_mime() {
  case "$1" in
    image/png) printf 'png\n' ;;
    image/jpeg) printf 'jpg\n' ;;
    image/webp) printf 'webp\n' ;;
    image/bmp) printf 'bmp\n' ;;
    image/tiff) printf 'tiff\n' ;;
    *) printf 'img\n' ;;
  esac
}

capture_clipboard() {
  local tmp_dir="$1"
  local mime=""
  local extension=""
  local types=""

  if grep -qiE '(microsoft|wsl)' /proc/version 2>/dev/null; then
    CAPTURED_FILE="$tmp_dir/sendshot-$(date +%Y%m%d-%H%M%S)-$$.png"
    local windows_file
    windows_file="$(wslpath -w "$CAPTURED_FILE")"

    powershell.exe -NoProfile -Command "
Add-Type -AssemblyName System.Windows.Forms;
Add-Type -AssemblyName System.Drawing;
\$image = [System.Windows.Forms.Clipboard]::GetImage();
if (\$null -eq \$image) {
  Write-Error 'Clipboard does not contain an image.';
  exit 1;
}
\$image.Save('$windows_file', [System.Drawing.Imaging.ImageFormat]::Png);
" >/dev/null 2>&1 ||
      die "Windows clipboard does not contain an image"

  elif [[ "$(uname -s)" == "Darwin" ]]; then
    CAPTURED_FILE="$tmp_dir/sendshot-$(date +%Y%m%d-%H%M%S)-$$.png"

    if command_exists pngpaste; then
      pngpaste "$CAPTURED_FILE" >/dev/null 2>&1 ||
        die "clipboard does not contain an image"
    else
      osascript \
        -e "set theFile to (POSIX file \"$CAPTURED_FILE\")" \
        -e 'set pngData to (the clipboard as «class PNGf»)' \
        -e 'set fileRef to (open for access theFile with write permission)' \
        -e 'write pngData to fileRef' \
        -e 'close access fileRef' >/dev/null 2>&1 ||
        die "clipboard does not contain a PNG image; install pngpaste for better compatibility"
    fi

  elif [[ "$(uname -s)" == "Linux" ]]; then
    if command_exists wl-paste &&
      { [[ -n "${WAYLAND_DISPLAY:-}" ]] || [[ "${XDG_SESSION_TYPE:-}" == "wayland" ]]; }; then
      types="$(wl-paste --list-types 2>/dev/null || true)"
      mime="$(choose_wayland_mime "$types")" ||
        die "Wayland clipboard does not contain a supported image"

      extension="$(extension_for_mime "$mime")"
      CAPTURED_FILE="$tmp_dir/sendshot-$(date +%Y%m%d-%H%M%S)-$$.$extension"

      wl-paste --no-newline --type "$mime" >"$CAPTURED_FILE" 2>/dev/null ||
        die "failed to read image from Wayland clipboard"

    elif command_exists xclip &&
      { [[ -n "${DISPLAY:-}" ]] || [[ "${XDG_SESSION_TYPE:-}" == "x11" ]]; }; then
      types="$(xclip -selection clipboard -t TARGETS -o 2>/dev/null || true)"

      if grep -Eq '(^|[[:space:]])image/png($|[[:space:]])' <<<"$types"; then
        mime="image/png"
      elif grep -Eq '(^|[[:space:]])image/jpeg($|[[:space:]])' <<<"$types"; then
        mime="image/jpeg"
      else
        die "X11 clipboard does not contain a PNG or JPEG image"
      fi

      extension="$(extension_for_mime "$mime")"
      CAPTURED_FILE="$tmp_dir/sendshot-$(date +%Y%m%d-%H%M%S)-$$.$extension"

      xclip -selection clipboard -t "$mime" -o >"$CAPTURED_FILE" 2>/dev/null ||
        die "failed to read image from X11 clipboard"

    else
      die "clipboard tool missing; Ubuntu Wayland: sudo apt install wl-clipboard; X11: sudo apt install xclip"
    fi

  else
    die "unsupported platform: $(uname -s)"
  fi

  [[ -s "$CAPTURED_FILE" ]] || die "captured image is empty"
}

copy_to_clipboard() {
  local value="$1"

  if command_exists clip.exe; then
    printf '%s' "$value" | clip.exe >/dev/null 2>&1
  elif command_exists pbcopy; then
    printf '%s' "$value" | pbcopy >/dev/null 2>&1
  elif command_exists wl-copy &&
    { [[ -n "${WAYLAND_DISPLAY:-}" ]] || [[ "${XDG_SESSION_TYPE:-}" == "wayland" ]]; }; then
    printf '%s' "$value" | wl-copy >/dev/null 2>&1
  elif command_exists xclip &&
    { [[ -n "${DISPLAY:-}" ]] || [[ "${XDG_SESSION_TYPE:-}" == "x11" ]]; }; then
    # xclip may fork a background selection owner. Redirect its output so the
    # process cannot keep a ZLE command-capture pipe open.
    printf '%s' "$value" |
      xclip -selection clipboard -in >/dev/null 2>&1
  else
    log "warning: could not copy remote path back to clipboard"
    return 1
  fi
}

resolve_remote_directory() {
  local target="$1"
  local quoted_remote_dir

  printf -v quoted_remote_dir '%q' "$REMOTE_DIR"

  ssh "${SSH_ARGS[@]}" "$target" "bash -s -- $quoted_remote_dir" <<'REMOTE_SCRIPT'
set -Eeuo pipefail

directory="$1"

case "$directory" in
  "~")
    directory="$HOME"
    ;;
  "~/"*)
    directory="$HOME/${directory:2}"
    ;;
esac

mkdir -p -- "$directory"
cd -- "$directory"
pwd -P
REMOTE_SCRIPT
}

send_image() (
  load_config

  [[ -n "$REMOTE_HOST" ]] || die "not configured; run: sendshot config"
  [[ -n "$REMOTE_USER" ]] || die "REMOTE_USER is missing"
  [[ -n "$REMOTE_DIR" ]] || die "REMOTE_DIR is missing"

  command_exists ssh || die "ssh is required"
  command_exists scp || die "scp is required"

  build_ssh_args

  local temp_dir
  temp_dir="$(mktemp -d "${TMPDIR:-/tmp}/sendshot.XXXXXX")"
  trap 'rm -rf "$temp_dir"' EXIT INT TERM HUP

  log "reading image from clipboard"
  capture_clipboard "$temp_dir"

  local target="${REMOTE_USER}@${REMOTE_HOST}"
  local remote_absolute_dir
  remote_absolute_dir="$(resolve_remote_directory "$target")" ||
    die "failed to create or resolve remote directory"

  [[ -n "$remote_absolute_dir" ]] || die "remote directory resolved to an empty value"

  log "uploading $(basename "$CAPTURED_FILE") to $target:$remote_absolute_dir"

  scp -q "${SCP_ARGS[@]}" \
    "$CAPTURED_FILE" \
    "$target:$remote_absolute_dir/" ||
    die "upload failed"

  local remote_path="$remote_absolute_dir/$(basename "$CAPTURED_FILE")"

  copy_to_clipboard "$remote_path" || true
  printf '%s\n' "$remote_path"
)

show_config() {
  load_config

  printf 'Config file : %s\n' "$CONFIG_FILE"
  printf 'Remote user: %s\n' "${REMOTE_USER:-<not set>}"
  printf 'Remote host: %s\n' "${REMOTE_HOST:-<not set>}"
  printf 'SSH key    : %s\n' "${SSH_KEY:-<SSH config/agent>}"
  printf 'SSH port   : %s\n' "${SSH_PORT:-22}"
  printf 'Remote dir : %s\n' "${REMOTE_DIR:-<not set>}"
}

doctor() {
  local failed=0

  printf 'sendshot %s\n' "$VERSION"
  printf 'OS          : %s\n' "$(uname -s)"
  printf 'Session type: %s\n' "${XDG_SESSION_TYPE:-unknown}"
  printf 'Shell       : %s\n' "${SHELL:-unknown}"

  if command_exists ssh && command_exists scp; then
    printf 'SSH tools   : OK\n'
  else
    printf 'SSH tools   : MISSING\n'
    failed=1
  fi

  if grep -qiE '(microsoft|wsl)' /proc/version 2>/dev/null; then
    command_exists powershell.exe &&
      printf 'Clipboard   : OK (WSL/PowerShell)\n' ||
      { printf 'Clipboard   : MISSING powershell.exe\n'; failed=1; }
  elif [[ "$(uname -s)" == "Darwin" ]]; then
    if command_exists pngpaste || command_exists osascript; then
      printf 'Clipboard   : OK (macOS)\n'
    else
      printf 'Clipboard   : MISSING pngpaste/osascript\n'
      failed=1
    fi
  elif [[ "${XDG_SESSION_TYPE:-}" == "wayland" || -n "${WAYLAND_DISPLAY:-}" ]]; then
    command_exists wl-paste && command_exists wl-copy &&
      printf 'Clipboard   : OK (Wayland)\n' ||
      { printf 'Clipboard   : MISSING wl-clipboard\n'; failed=1; }
  else
    command_exists xclip &&
      printf 'Clipboard   : OK (X11)\n' ||
      { printf 'Clipboard   : MISSING xclip\n'; failed=1; }
  fi

  if [[ -f "$CONFIG_FILE" ]]; then
    printf 'Config      : OK (%s)\n' "$CONFIG_FILE"
    if test_connection; then
      printf 'Remote SSH  : OK\n'
    else
      failed=1
    fi
  else
    printf 'Config      : MISSING (run: sendshot config)\n'
    failed=1
  fi

  return "$failed"
}

usage() {
  cat <<'EOF'
Usage:
  sendshot                 Upload clipboard image
  sendshot send            Upload clipboard image
  sendshot config          Interactive EC2/SSH configuration
  sendshot show-config     Display current configuration
  sendshot test            Test SSH connection
  sendshot doctor          Check local dependencies and remote connection
  sendshot check-update    Check for a new version and ask whether to update
  sendshot update          Download and install the latest version
  sendshot update --force  Reinstall the remote version even if unchanged
  sendshot install-hotkey  Install or refresh Ctrl+G shell integration
  sendshot version         Display version
  sendshot help            Display this help

Configuration fields:
  Remote SSH user
  Remote host/IP or SSH alias
  SSH private key path (optional)
  SSH port
  EC2 remote image directory

Non-interactive configuration:
  SENDSHOT_NON_INTERACTIVE=1 \
  SENDSHOT_REMOTE_USER=ubuntu \
  SENDSHOT_REMOTE_HOST=example.com \
  SENDSHOT_SSH_KEY=~/.ssh/example.pem \
  SENDSHOT_SSH_PORT=22 \
  SENDSHOT_REMOTE_DIR=~/tmp_images \
  sendshot config
EOF
}

main() {
  local command="${1:-send}"

  case "$command" in
    update)
      if [[ "${2:-}" == "--force" ]]; then
        perform_update 1
      else
        perform_update 0
      fi
      ;;
    check-update)
      check_update_interactive manual
      ;;
    install-hotkey)
      refresh_shell_integrations
      ;;
    version|--version|-v)
      printf 'sendshot %s\n' "$VERSION"
      ;;
    help|--help|-h)
      usage
      ;;
    send)
      maybe_check_for_update "$@"
      send_image
      ;;
    config)
      maybe_check_for_update "$@"
      configure
      ;;
    show-config)
      maybe_check_for_update "$@"
      show_config
      ;;
    test)
      maybe_check_for_update "$@"
      test_connection
      ;;
    doctor)
      maybe_check_for_update "$@"
      doctor
      ;;
    *)
      usage >&2
      exit 2
      ;;
  esac
}

main "$@"
